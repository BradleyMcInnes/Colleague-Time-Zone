modules = ["nodejs-24"]

  [[artifacts]]
  id = "artifacts/api-server"

  [[artifacts]]
  id = "artifacts/mockup-sandbox"

  [deployment]
  deploymentTarget = "static"
  publicDir = "artifacts/timezone-tool/dist/public"

  [deployment.build]
  args = ["pnpm", "--filter", "@workspace/timezone-tool", "build"]

  [deployment.postBuild]
  args = ["pnpm", "store", "prune"]
  env = { "CI" = "true" }

  [workflows]
  runButton = "Project"

  [agent]
  stack = "PNPM_WORKSPACE"
  expertMode = true

  [postMerge]
  path = "scripts/post-merge.sh"
  timeoutMs = 20000
  